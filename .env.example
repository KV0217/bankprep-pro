# BankPrep Pro — Environment Variables
# Copy this file to .env and fill in your keys

# Groq API Key (FREE — 14,400 req/day)
# Get it at: console.groq.com → API Keys → Create key
GROQ_KEY=gsk_your_groq_key_here

# GNews API Key (FREE — 100 req/day, for live Indian news)
# Get it at: gnews.io → Sign up → My Account → API Key
# Optional — without this, AI generates news content
GNEWS_KEY=your_gnews_key_here

# Port (Railway/Render set this automatically)
PORT=3000
